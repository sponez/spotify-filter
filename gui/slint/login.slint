import { Button } from "std-widgets.slint";

export component LoginView {
    width: 360px;
    height: 240px;

    callback signIn();

    VerticalLayout {
        padding: root.width * 25%;

        Button {
            text: "Sign in with Spotify";
            width: 100%;

            clicked => {
                root.signIn();
            }
        }
    }
}
